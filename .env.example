# =============================================================================
# TUTORCLOUD GLOBAL DASHBOARD - ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and configure with your actual values
# NEVER commit .env file to version control
# =============================================================================

# --------------------------------
# APPLICATION SETTINGS
# --------------------------------
APP_NAME=TutorCloud Global Education Dashboard
APP_VERSION=1.0.0
APP_ENV=development  # development | staging | production
DEBUG=True
SECRET_KEY=your-secret-key-change-this-in-production

# Server Configuration
HOST=0.0.0.0
PORT=8050
WORKERS=4  # For production with gunicorn

# --------------------------------
# DATABASE CONFIGURATION
# --------------------------------
# PostgreSQL Connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tutorcloud_db
DB_USER=tutorcloud_admin
DB_PASSWORD=your-secure-password
DB_SCHEMA=india_2024_25

# Connection Pool Settings
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# Query Timeout (seconds)
DB_QUERY_TIMEOUT=30

# --------------------------------
# REDIS CACHE CONFIGURATION
# --------------------------------
REDIS_ENABLED=True
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
CACHE_DEFAULT_TIMEOUT=300  # 5 minutes
CACHE_MV_TIMEOUT=3600  # 1 hour for materialized views

# --------------------------------
# LOGGING CONFIGURATION
# --------------------------------
LOG_LEVEL=INFO  # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FILE=logs/tutorcloud.log
LOG_MAX_BYTES=10485760  # 10MB
LOG_BACKUP_COUNT=5
LOG_FORMAT=json  # json | text

# --------------------------------
# DASHBOARD CONFIGURATION
# --------------------------------
# Default Region & Academic Year
DEFAULT_REGION=India
DEFAULT_ACADEMIC_YEAR=2024-25

# Data Refresh Intervals (seconds)
MV_REFRESH_INTERVAL=3600  # 1 hour
METRICS_REFRESH_INTERVAL=300  # 5 minutes

# Pagination
DEFAULT_PAGE_SIZE=50
MAX_PAGE_SIZE=1000

# Export Limits
MAX_EXPORT_ROWS=100000

# --------------------------------
# FEATURE FLAGS
# --------------------------------
ENABLE_CACHING=True
ENABLE_EXPORT=True
ENABLE_MAPS=True
ENABLE_COMPARISON=True
ENABLE_ADVANCED_FILTERS=True
ENABLE_SCHOOL_SEARCH=True

# --------------------------------
# GEOSPATIAL DATA
# --------------------------------
GEOJSON_PATH=data/geojson
ENABLE_DISTRICT_MAPS=True
ENABLE_BLOCK_MAPS=False  # Resource intensive

# --------------------------------
# SECURITY (Future Implementation)
# --------------------------------
ENABLE_AUTH=False
JWT_SECRET_KEY=your-jwt-secret-key
JWT_EXPIRY_HOURS=24
ALLOWED_ORIGINS=*  # Comma-separated list or *

# --------------------------------
# MONITORING & ANALYTICS
# --------------------------------
ENABLE_MONITORING=False
SENTRY_DSN=
GOOGLE_ANALYTICS_ID=

# --------------------------------
# MULTI-REGION SUPPORT (Future)
# --------------------------------
REGIONS=India,USA,Australia,New Zealand,UAE
DEFAULT_TIMEZONE=Asia/Kolkata

# --------------------------------
# API CONFIGURATION (Future)
# --------------------------------
API_ENABLED=False
API_RATE_LIMIT=100  # requests per minute
API_KEY=

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
# Directory for log files (default: logs)
LOG_DIR=logs

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL (default: INFO)
LOG_LEVEL=INFO

# Maximum size per log file in bytes (default: 10485760 = 10 MB)
LOG_MAX_BYTES=10485760

# Number of backup log files to keep (default: 5)
LOG_BACKUP_COUNT=5

# Enable console output (default: True)
LOG_CONSOLE=True

# Enable JSON formatting for file logs (default: False)
LOG_JSON=False

