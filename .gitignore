# =============================================================================
# .gitignore - TutorCloud Global Dashboard
# =============================================================================

# --------------------------------
# Python
# --------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# --------------------------------
# Environment & Configuration
# --------------------------------
.env
.env.local
.env.*.local
*.local
config/*.local.yaml
secrets/

# --------------------------------
# IDE & Editors
# --------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --------------------------------
# Logs
# --------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --------------------------------
# Database
# --------------------------------
*.db
*.sqlite
*.sqlite3
*.db-journal
migrations/versions/*.pyc

# --------------------------------
# Testing
# --------------------------------
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/
.pytest_cache/

# --------------------------------
# Jupyter Notebook
# --------------------------------
.ipynb_checkpoints
*.ipynb

# --------------------------------
# Cache & Temp Files
# --------------------------------
.cache/
*.cache
tmp/
temp/
.tmp/

# --------------------------------
# Documentation
# --------------------------------
docs/_build/
site/

# --------------------------------
# Data Files (keep structure, ignore data)
# --------------------------------
data/raw/*.csv
data/raw/*.xlsx
data/processed/*.csv
data/processed/*.parquet
data/backups/

# Keep .gitkeep files
!.gitkeep

# --------------------------------
# Assets (large files)
# --------------------------------
*.png
*.jpg
*.jpeg
*.gif
*.pdf
assets/uploads/

# Keep specific assets
!assets/images/logo.png
!docs/**/*.png

# --------------------------------
# OS Files
# --------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Desktop.ini

# --------------------------------
# Distribution / Packaging
# --------------------------------
*.tar.gz
*.zip
*.whl

# --------------------------------
# Virtual Environments
# --------------------------------
venv/
ENV/
env/
.venv/

# --------------------------------
# Monitoring & Profiling
# --------------------------------
*.prof
*.lprof
prof/
.profiling/

# --------------------------------
# Redis
# --------------------------------
dump.rdb

# --------------------------------
# Docker
# --------------------------------
*.pid
*.seed
*.pid.lock
