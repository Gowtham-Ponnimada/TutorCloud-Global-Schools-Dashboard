@st.cache_data(ttl=3600, show_spinner=False)
def get_all_states():
    """Get list of all states"""
    conn = get_db_connection()
    if not conn:
        return []
    
    try:
        query = f"""
        SELECT DISTINCT {COL_STATE_NAME} as state
        FROM {SCHEMA}.{TABLE_SCHOOL_PROFILE}
        WHERE {COL_STATE_NAME} IS NOT NULL
        ORDER BY state
        """
        df = pd.read_sql_query(query, conn)
        conn.close()
        return df['state'].tolist()
    except Exception as e:
        st.error(f"Error fetching states: {str(e)}")
        if conn:
            conn.close()
        return []

@st.cache_data(ttl=3600, show_spinner=False)
def get_districts_for_state(state_name):
    """Get list of districts for a state"""
    conn = get_db_connection()
    if not conn:
        return []
    
    try:
        query = f"""
        SELECT DISTINCT {COL_DISTRICT_NAME} as district
        FROM {SCHEMA}.{TABLE_SCHOOL_PROFILE}
        WHERE UPPER({COL_STATE_NAME}) = %s
        AND {COL_DISTRICT_NAME} IS NOT NULL
        ORDER BY district
        """
        df = pd.read_sql_query(query, conn, params=(state_name.upper(),))
        conn.close()
        return df['district'].tolist()
    except Exception as e:
        if conn:
            conn.close()
        return []

