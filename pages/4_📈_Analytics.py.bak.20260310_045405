        LEFT JOIN enrollment_data ed ON sp.pseudocode = ed.pseudocode
        LEFT JOIN teacher_data td ON sp.pseudocode = td.pseudocode
        WHERE UPPER(sp.{COL_STATE_NAME}) = %s
        AND sp.{COL_DISTRICT_NAME} IS NOT NULL
        GROUP BY UPPER(sp.{COL_DISTRICT_NAME})
        ORDER BY district
        """
        
        df = pd.read_sql_query(query, conn, params=(state_name.upper(),))
        conn.close()
